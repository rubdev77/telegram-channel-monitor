# Pyrogram credentials — https://my.telegram.org/apps
API_ID=12345678
API_HASH=0123456789abcdef0123456789abcdef

# User-account session string (generate once with generate_session.py)
SESSION_STRING=

# Admin bot token from @BotFather (serves the inline-keyboard UI)
BOT_TOKEN=123456:ABC-DEF...

# Your own Telegram user ID (the only user allowed to use the admin UI)
ADMIN_USER_ID=123456789

# Fixed private alert channel ID (the -100... form; user account must be admin there to pin)
TARGET_CHANNEL_ID=-1001234567890

# Cloud database (recommended for deployment). When set, PostgreSQL is used;
# when empty/absent, a local SQLite file is used instead.
# Get a free one from Koyeb (Databases tab), Neon (neon.tech) or Supabase.
# DATABASE_URL=postgres://user:password@host:5432/dbname?sslmode=require

# Optional
# DB_PATH=bot_data.db
# PORT=8080
